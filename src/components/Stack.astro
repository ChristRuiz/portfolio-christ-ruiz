---
import { Layers } from "@lucide/astro";
import { categoriasStack } from "../data/stack";
---

<section
  id="stack"
  class="relative min-h-screen w-full bg-slate-900/98 px-4 py-20 sm:px-6 md:px-8"
>
  <div class="container relative mx-auto max-w-5xl">
    <div class="mb-16 text-center" data-aos="fade-up">
      <div class="mb-6 inline-block">
        <div class="relative">
          <div
            class="absolute inset-0 animate-pulse rounded-2xl bg-linear-to-r from-orange-500/20 to-orange-400/20 blur-xl"
          >
          </div>
          <div
            class="relative flex items-center gap-3 rounded-2xl border border-orange-500/20 bg-slate-800/95 px-6 py-3 backdrop-blur-md"
          >
            <Layers class="h-6 w-6 text-orange-500" />
            <span
              class="text-sm font-semibold uppercase tracking-wider text-orange-400"
              >Tecnologías</span
            >
          </div>
        </div>
      </div>
      <h2
        class="mb-4 bg-linear-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-4xl font-bold text-transparent sm:text-5xl md:text-6xl"
      >
        Stack tecnológico
      </h2>
      <div
        class="prose prose-invert mx-auto max-w-2xl max-w-none prose-p:text-center prose-p:text-slate-400"
      >
        <p>Herramientas y lenguajes con los que trabajo a diario</p>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-2">
      {
        categoriasStack.map((cat, i) => {
          const Icono = cat.icono;
          return (
            <div
              class="group relative overflow-hidden rounded-2xl border-2 border-slate-700/50 bg-slate-800/95 transition-all duration-500 hover:scale-[1.02] hover:border-orange-500/50 hover:shadow-2xl hover:shadow-orange-500/20"
              data-aos="fade-up"
              data-aos-delay={i * 100}
            >
              <div class="absolute left-0 top-0 h-full w-1 bg-orange-500/30" />
              <div class="relative z-10 p-6 pl-7">
                <div class="mb-5 flex items-center gap-3">
                  <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-orange-500/20 bg-slate-900/70">
                    <Icono class="h-6 w-6 text-orange-500" />
                  </div>
                  <h3 class="text-xl font-bold text-white sm:text-2xl">
                    {cat.titulo}
                  </h3>
                </div>
                <div class="flex flex-wrap gap-3">
                  {cat.tecnologias.map((tech) => (
                    <span class="inline-flex items-center gap-2 rounded-xl border border-orange-500/20 bg-slate-900/70 px-4 py-2.5 text-sm font-medium text-orange-400 transition-all duration-200 hover:scale-105 hover:border-orange-500/40 hover:bg-orange-500/10">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

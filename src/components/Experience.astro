---
import { Briefcase, Calendar } from "@lucide/astro";
import { experiencias } from "../data/experiencia";
---

<section
  id="experience"
  class="relative min-h-screen w-full bg-slate-900/98 px-4 py-20 sm:px-6 md:px-8"
>
  <div class="container mx-auto max-w-4xl">
    <div class="mb-16 text-center" data-aos="fade-up">
      <div class="mb-6 inline-block">
        <div class="relative">
          <div
            class="absolute inset-0 animate-pulse rounded-2xl bg-linear-to-r from-orange-500/20 to-orange-400/20 blur-xl"
          >
          </div>
          <div
            class="relative flex items-center gap-3 rounded-2xl border border-orange-500/20 bg-slate-800/95 px-6 py-3 backdrop-blur-md"
          >
            <Briefcase class="h-6 w-6 text-orange-500" />
            <span
              class="text-sm font-semibold uppercase tracking-wider text-orange-400"
              >Trayectoria Profesional</span
            >
          </div>
        </div>
      </div>
      <h2
        class="mb-4 bg-linear-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-4xl font-bold text-transparent sm:text-5xl md:text-6xl"
      >
        Experiencia Laboral
      </h2>
      <div
        class="prose prose-invert mx-auto max-w-2xl max-w-none prose-p:text-center prose-p:text-slate-400"
      >
        <p>Construyendo soluciones innovadoras con las tecnologías más avanzadas</p>
      </div>
    </div>

    <div class="relative">
      <div
        class="absolute top-0 bottom-0 left-4 w-0.5 bg-linear-to-b from-orange-500 via-orange-500/50 to-transparent sm:left-6 md:left-1/2 md:-translate-x-1/2"
      >
      </div>

      {
        experiencias.map((exp, i) => (
          <div
            class="relative mb-12 md:mb-16"
            data-aos="fade-up"
            data-aos-delay={i * 150}
          >
            <div class="absolute top-6 left-4 sm:left-6 md:top-8 md:left-1/2">
              <div class="relative h-5 w-5 -translate-x-1/2 sm:h-6 sm:w-6 md:h-7 md:w-7">
                <div class="absolute inset-0 animate-ping rounded-full bg-orange-500/50" />
                <div class="relative h-5 w-5 rounded-full border-4 border-orange-500 bg-slate-900 shadow-lg shadow-orange-500/50 sm:h-6 sm:w-6 md:h-7 md:w-7" />
              </div>
            </div>

            <div
              class:list={[
                "ml-12 sm:ml-16 md:ml-0 md:w-[calc(50%-2.5rem)]",
                i % 2 !== 0 ? "md:ml-auto" : "md:mr-auto",
              ]}
            >
              <div class="group relative overflow-hidden rounded-2xl border-2 border-slate-700/50 bg-linear-to-br from-slate-800/95 to-slate-800/90 p-6 backdrop-blur-md transition-all duration-500 hover:scale-[1.02] hover:border-orange-500/50 hover:shadow-2xl hover:shadow-orange-500/20 sm:p-7">
                <div class="absolute inset-0 bg-linear-to-br from-orange-500/0 via-orange-500/5 to-orange-500/10 opacity-0 transition-opacity duration-500 group-hover:opacity-100" />

                <div class="relative z-10">
                  <div class="mb-4 flex items-center justify-between">
                    <div class="flex items-center gap-2 text-orange-400">
                      <Calendar class="h-4 w-4 sm:h-5 sm:w-5" />
                      <span class="text-xs font-medium sm:text-sm">
                        {exp.startDate} - {exp.endDate}
                      </span>
                    </div>
                    <Briefcase class="h-5 w-5 text-orange-500/40 transition-all duration-300 group-hover:scale-110 group-hover:text-orange-500 sm:h-6 sm:w-6" />
                  </div>

                  <h3 class="mb-2 text-xl font-bold text-white transition-colors duration-300 group-hover:text-orange-400 sm:text-2xl md:text-3xl">
                    {exp.company}
                  </h3>

                  <h4 class="mb-4 text-base font-semibold text-orange-500 sm:text-lg md:text-xl">
                    {exp.role}
                  </h4>

                  <div
                    class="prose prose-invert mb-6 max-w-none prose-p:mb-0 prose-p:leading-relaxed prose-sm sm:prose-base"
                  >
                    <p>{exp.description}</p>
                  </div>

                  <div class="flex flex-wrap gap-2">
                    {exp.technologies.map((tech) => (
                      <span class="rounded-full border border-orange-500/20 bg-slate-900/70 px-3 py-1 text-xs font-medium text-orange-400 transition-all duration-200 hover:scale-105 hover:border-orange-500/40 hover:bg-orange-500/10 sm:text-sm">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>

                <div class="pointer-events-none absolute -top-12 -right-12 h-32 w-32 rounded-full bg-orange-500/10 opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-100" />
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

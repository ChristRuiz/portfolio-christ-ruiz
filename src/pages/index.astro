---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Stack from "../components/Stack.astro";
import Experience from "../components/Experience.astro";
import "../styles/global.css";
---

<Layout>
  <div class="pointer-events-none fixed inset-0 z-0 overflow-hidden bg-slate-950">
    <video
      autoplay
      loop
      muted
      playsinline
      class="animate-blurred-fade-in h-full w-full object-cover opacity-100"
      poster=""
      style="animation-delay: 2.1s"
      oncanplay="this.playbackRate=2.0"
    >
      <source src="/assets/videos/background.webm" type="video/webm" />
    </video>
    <div class="absolute inset-0 bg-linear-to-b from-slate-950/20 via-slate-950/10 to-slate-950/20"></div>
  </div>

  <div class="relative z-10">
    <Nav />
    <Hero />
    <Stack />
    <Experience />
  </div>
</Layout>

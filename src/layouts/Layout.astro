---
import { ClientRouter } from "astro:transitions";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title = site.title, description = site.description, image = site.image } =
  Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Christian Ruiz" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content="es_ES" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Christian Ruiz",
      "url": canonicalURL,
      "image": new URL(image, Astro.site),
      "jobTitle": "Desarrollador Full Stack",
      "description": description,
      "knowsAbout": ["Angular", "Java", "Spring Boot", "TypeScript", "Node.js", "PostgreSQL", "Docker", "AWS"],
      "sameAs": [site.linkedinUrl]
    })} />
    <ClientRouter />
  </head>
  <body>
    <slot />

    <script>
      import AOS from "aos";

      document.addEventListener("astro:page-load", () => {
        AOS.init({ duration: 800, easing: "ease-in-out", once: true, offset: 100, delay: 100 });
        AOS.refresh();
      });
    </script>
  </body>
</html>

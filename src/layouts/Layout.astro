---
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import { site } from "../data/site";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title?: string;
  description?: string;
  /** Ruta absoluta desde / para la imagen de redes (Open Graph / Twitter). */
  image?: string;
}

const {
  title = site.title,
  description = site.description,
  image = site.socialImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
const profileImageURL = new URL(site.profileImage, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Christian Ruiz" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.siteName} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content={String(site.socialImageWidth)} />
    <meta property="og:image:height" content={String(site.socialImageHeight)} />
    <meta property="og:image:alt" content={site.socialImageAlt} />
    <meta property="og:locale" content="es_ES" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL.href} />
    <meta name="twitter:image:alt" content={site.socialImageAlt} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Christian Ruiz",
        url: canonicalURL,
        image: profileImageURL,
        jobTitle: "Desarrollador Full Stack",
        description: description,
        knowsAbout: [
          "Angular",
          "Java",
          "Spring Boot",
          "TypeScript",
          "Node.js",
          "PostgreSQL",
          "Docker",
          "AWS",
        ],
        sameAs: [site.linkedinUrl],
      })}
    />
    <Font cssVariable="--font-calibre" preload />
    <ClientRouter />
    <Analytics />
    <SpeedInsights />
  </head>
  <body>
    <slot />

    <script>
      import AOS from "aos";

      document.addEventListener("astro:page-load", () => {
        AOS.init({
          duration: 800,
          easing: "ease-in-out",
          once: true,
          offset: 100,
          delay: 100,
        });
        AOS.refresh();
      });
    </script>
  </body>
</html>
